+static void tp_tap_touch4_handle_event(struct tp_dispatch *tp, struct tp_touch *t, enum tap_event event, usec_t time) {
+	switch (event) {
+	case TAP_EVENT_TOUCH:
+		tp->tap.state = TAP_STATE_DEAD;
+		tp_tap_clear_timer(tp);
+		break;
+	case TAP_EVENT_MOTION:
+		tp_tap_move_to_dead(tp, t);
+		break;
+	case TAP_EVENT_TIMEOUT:
+		tp->tap.state = TAP_STATE_TOUCH_4_HOLD;
+		tp_tap_clear_timer(tp);
+		break;
+	case TAP_EVENT_RELEASE:
+		tp->tap.state = TAP_STATE_TOUCH_4_RELEASE;
+		tp->tap.saved_release_time = time;
+		tp_tap_set_timer(tp, time);
+		break;
+	case TAP_EVENT_BUTTON: tp->tap.state = TAP_STATE_DEAD; break;
+	case TAP_EVENT_THUMB: break;
+	case TAP_EVENT_PALM: tp->tap.state = TAP_STATE_TOUCH_3; break;
+	case TAP_EVENT_PALM_UP: break;
+	}
+}
+
+static void tp_tap_touch4_hold_handle_event(struct tp_dispatch *tp, struct tp_touch *t, enum tap_event event, usec_t time) {
+	switch (event) {
+	case TAP_EVENT_TOUCH:
+		tp->tap.state = TAP_STATE_DEAD;
+		tp_tap_set_timer(tp, time);
+		break;
+	case TAP_EVENT_RELEASE: tp->tap.state = TAP_STATE_TOUCH_3_HOLD; break;
+	case TAP_EVENT_MOTION: tp_tap_move_to_dead(tp, t); break;
+	case TAP_EVENT_TIMEOUT: break;
+	case TAP_EVENT_BUTTON: tp->tap.state = TAP_STATE_DEAD; break;
+	case TAP_EVENT_THUMB: break;
+	case TAP_EVENT_PALM: tp->tap.state = TAP_STATE_TOUCH_3_HOLD; break;
+	case TAP_EVENT_PALM_UP: break;
+	}
+}
+
+static void tp_tap_touch4_release_handle_event(struct tp_dispatch *tp, struct tp_touch *t, enum tap_event event, usec_t time) {
+	switch (event) {
+	case TAP_EVENT_TOUCH:
+		tp_tap_notify(tp, tp->tap.saved_press_time, 4, LIBINPUT_BUTTON_STATE_PRESSED);
+		tp_tap_notify(tp, tp->tap.saved_release_time, 4, LIBINPUT_BUTTON_STATE_RELEASED);
+		tp->tap.state = TAP_STATE_TOUCH_4;
+		tp->tap.saved_press_time = time;
+		tp_tap_set_timer(tp, time);
+		break;
+	case TAP_EVENT_RELEASE:
+		tp->tap.state = TAP_STATE_TOUCH_4_RELEASE_2;
+		tp_tap_set_timer(tp, time);
+		break;
+	case TAP_EVENT_MOTION:
+	case TAP_EVENT_TIMEOUT:
+	case TAP_EVENT_BUTTON:
+		tp_tap_notify(tp, tp->tap.saved_press_time, 4, LIBINPUT_BUTTON_STATE_PRESSED);
+		tp_tap_notify(tp, tp->tap.saved_release_time, 4, LIBINPUT_BUTTON_STATE_RELEASED);
+		tp->tap.state = (event == TAP_EVENT_TIMEOUT) ? TAP_STATE_TOUCH_3_HOLD : TAP_STATE_DEAD;
+		break;
+	case TAP_EVENT_THUMB: break;
+	case TAP_EVENT_PALM: tp->tap.state = TAP_STATE_TOUCH_3_RELEASE; break;
+	case TAP_EVENT_PALM_UP: break;
+	}
+}
+
+static void tp_tap_touch4_release2_handle_event(struct tp_dispatch *tp, struct tp_touch *t, enum tap_event event, usec_t time) {
+	switch (event) {
+	case TAP_EVENT_TOUCH:
+		tp_tap_notify(tp, tp->tap.saved_press_time, 4, LIBINPUT_BUTTON_STATE_PRESSED);
+		tp_tap_notify(tp, tp->tap.saved_release_time, 4, LIBINPUT_BUTTON_STATE_RELEASED);
+		tp->tap.state = TAP_STATE_TOUCH_3;
+		tp->tap.saved_press_time = time;
+		tp_tap_set_timer(tp, time);
+		break;
+	case TAP_EVENT_RELEASE:
+		tp->tap.state = TAP_STATE_TOUCH_4_RELEASE_3;
+		tp_tap_set_timer(tp, time);
+		break;
+	case TAP_EVENT_MOTION:
+	case TAP_EVENT_TIMEOUT:
+	case TAP_EVENT_BUTTON:
+		tp_tap_notify(tp, tp->tap.saved_press_time, 4, LIBINPUT_BUTTON_STATE_PRESSED);
+		tp_tap_notify(tp, tp->tap.saved_release_time, 4, LIBINPUT_BUTTON_STATE_RELEASED);
+		tp->tap.state = (event == TAP_EVENT_TIMEOUT) ? TAP_STATE_HOLD : TAP_STATE_DEAD;
+		break;
+	case TAP_EVENT_THUMB: break;
+	case TAP_EVENT_PALM: tp->tap.state = TAP_STATE_TOUCH_3_RELEASE_2; break;
+	case TAP_EVENT_PALM_UP: break;
+	}
+}
+
+static void tp_tap_touch4_release3_handle_event(struct tp_dispatch *tp, struct tp_touch *t, enum tap_event event, usec_t time) {
+	switch (event) {
+	case TAP_EVENT_RELEASE:
+		tp_tap_notify(tp, tp->tap.saved_press_time, 4, LIBINPUT_BUTTON_STATE_PRESSED);
+		tp_tap_notify(tp, tp->tap.saved_release_time, 4, LIBINPUT_BUTTON_STATE_RELEASED);
+		tp->tap.state = TAP_STATE_IDLE; // no hold states
+		break;
+	case TAP_EVENT_TOUCH:
+	case TAP_EVENT_MOTION:
+	case TAP_EVENT_TIMEOUT:
+	case TAP_EVENT_BUTTON:
+		tp_tap_notify(tp, tp->tap.saved_press_time, 4, LIBINPUT_BUTTON_STATE_PRESSED);
+		tp_tap_notify(tp, tp->tap.saved_release_time, 4, LIBINPUT_BUTTON_STATE_RELEASED);
+		tp->tap.state = (event == TAP_EVENT_TOUCH) ? TAP_STATE_TOUCH_2 : TAP_STATE_DEAD;
+		if (event == TAP_EVENT_TOUCH) {
+			tp->tap.saved_press_time = time;
+			tp_tap_set_timer(tp, time);
+		}
+		break;
+	case TAP_EVENT_THUMB: break;
+	case TAP_EVENT_PALM: tp->tap.state = TAP_STATE_IDLE; break; // simplified palm exit
+	case TAP_EVENT_PALM_UP: break;
+	}
+}
